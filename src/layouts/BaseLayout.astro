---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  canonicalUrl?: string;
}

const {
  title,
  description = 'A personal technical journal on software engineering, AI, physics, and independent research.',
  type = 'website',
  publishedTime,
  modifiedTime,
  canonicalUrl
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      canonicalUrl={canonicalUrl}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="AnshumanHQ Journal" href="/rss.xml" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-surface focus:text-text focus:px-3 focus:py-2 focus:rounded-md focus:z-[100]">
      Skip to content
    </a>
    <slot />
  </body>
</html>
