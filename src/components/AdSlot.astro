---
interface Props {
  slotId: string;
  format?: 'auto' | 'autorelaxed' | 'rectangle';
}

const { slotId, format = 'autorelaxed' } = Astro.props;
---

<div class="my-10" aria-label="Advertisement">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-2633513915753897"
    data-ad-slot={slotId}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>