---
const year = new Date().getFullYear();

const exploreLinks = [
  { label: 'Writing', href: '/writing' },
  { label: 'Research', href: '/writing?category=Research' },
  { label: 'Projects', href: '/writing?category=Projects' },
  { label: 'Search', href: '/search' }
];

const categoryLinks = [
  { label: 'Engineering', href: '/writing?category=Engineering' },
  { label: 'AI & ML', href: '/writing?category=AI%20%26%20ML' },
  { label: 'Learning', href: '/writing?category=Learning' }
];

const elsewhereLinks = [
  { label: 'GitHub', href: 'https://github.com/anshuman365' },
  { label: 'Main Website', href: 'https://anshumanhq.github.io' },
  { label: 'RSS Feed', href: '/rss.xml' }
];
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-5xl px-6 py-14 grid gap-10 sm:grid-cols-4">
    <div class="sm:col-span-2">
      <p class="font-mono text-sm text-text">ANSHUMAN BLOGS</p>
      <p class="text-sm text-muted mt-3 max-w-sm">
        A personal technical journal on software engineering, AI, physics, mathematics, and
        independent research — written and maintained by Anshuman Singh.
      </p>
      <p class="text-xs text-muted mt-4">&copy; {year} Anshuman Singh. Built with Astro.</p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-muted mb-3">Explore</p>
      <ul class="space-y-2">
        {exploreLinks.map((link) => (
          <li><a href={link.href} class="nav-link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-xs uppercase tracking-widest text-muted mb-3">Categories</p>
      <ul class="space-y-2">
        {categoryLinks.map((link) => (
          <li><a href={link.href} class="nav-link">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="mx-auto max-w-5xl px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-muted">Notes from building, learning, and investigating.</p>
      <div class="flex gap-5 text-sm">
        {elsewhereLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
