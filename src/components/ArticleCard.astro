---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { title, description, type, category, pubDate, readingTime } = entry.data;

const dateStr = pubDate instanceof Date && !isNaN(pubDate.getTime())
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : '';
---

<a
  href={`/writing/${entry.slug}`}
  class="block py-6 border-b border-border group"
  data-category={category}
  data-type={type}
>
  <span class="category-label">{category} · {type}</span>
  <h3 class="mt-2 text-lg font-medium group-hover:text-accent transition-colors">{title}</h3>
  <p class="mt-1 text-sm text-muted line-clamp-2">{description}</p>
  <p class="mt-2 text-xs text-muted font-mono">{readingTime}{dateStr ? ` · ${dateStr}` : ''}</p>
</a>
