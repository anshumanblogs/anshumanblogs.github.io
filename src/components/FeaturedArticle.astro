---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { title, description, type, category, readingTime } = entry.data;
---

<a
  href={`/writing/${entry.slug}`}
  class="block border border-border rounded-lg p-8 hover:border-accent/50 transition-colors"
>
  <span class="category-label">Featured · {category}</span>
  <h2 class="mt-3 text-2xl sm:text-3xl font-serif font-semibold leading-snug">{title}</h2>
  <p class="mt-3 text-muted max-w-2xl">{description}</p>
  <p class="mt-4 text-sm text-muted font-mono">{type} · {readingTime}</p>
</a>
