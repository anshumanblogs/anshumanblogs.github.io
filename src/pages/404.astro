---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found" description="This page doesn't exist.">
  <Header />

  <main id="main-content" class="mx-auto max-w-2xl px-6 py-24 text-center">
    <p class="category-label">404</p>
    <h1 class="mt-3 text-3xl font-serif font-semibold">This page doesn't exist.</h1>
    <p class="mt-3 text-muted">
      The article or page you're looking for may have moved, been renamed, or never existed.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <a href="/" class="btn-primary">Back Home</a>
      <a href="/writing" class="btn-secondary">Browse Writing</a>
    </div>
  </main>

  <Footer />
</BaseLayout>
